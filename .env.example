# Email Configuration for Order System
# Copy this file to .env.local and fill in your actual values

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Email Account Credentials
# SMTP_USER: The email account used to send order emails
SMTP_USER=your-email@gmail.com

# SMTP_PASSWORD: For Gmail, use an App Password (not your regular password)
# To generate a Gmail App Password:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate a new app password for "Mail"
# 4. Use that 16-character password here
SMTP_PASSWORD=your-app-password-here

# ORDER_EMAIL: The email address where orders will be delivered
# This can be the same as SMTP_USER or a different email
ORDER_EMAIL=orders@yourrestaurant.com
